# Job Hunt Automation — Environment Variables
# Copy this to .env and fill in real values. Never commit .env to git.

# ── Job Search APIs (free tiers) ──

# JSearch via RapidAPI — 50 req/month, 50 jobs/req = 2500 jobs/month
# Sign up: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Subscribe to the BASIC (free) plan, copy the X-RapidAPI-Key
JSEARCH_API_KEY=

# Adzuna — 100 req/day, country-specific job listings
# Sign up: https://developer.adzuna.com/ (free account)
# Get APP_ID and APP_KEY from your dashboard
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# SerpApi — 100 searches/month, Google Jobs results
# Sign up: https://serpapi.com/ (free: 100 searches)
# Copy your API key from the dashboard
SERPAPI_API_KEY=

# Apify — 10 compute units/month free, for JS-heavy sites (Workday, etc.)
# Sign up: https://apify.com/ (free tier)
APIFY_TOKEN=